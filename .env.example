# FreeTier Atlas — local development environment variables.
#
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
#
# These are NON-SECRET local development defaults. Never put real credentials in
# this file or in `.env`; `.env` is git-ignored. Production values are supplied
# by the deployment environment, not by the repository.

# --- PostgreSQL (used by the postgres service) ---
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_DB=atlas
POSTGRES_PORT=5432

# --- API service ---
# SQLAlchemy URL. Inside Docker Compose the host is the `postgres` service name.
DATABASE_URL=postgresql+psycopg://atlas:atlas@postgres:5432/atlas  # pragma: allowlist secret
APP_ENV=development
API_PORT=8000
