# FreeTier Atlas — local development environment variables.
#
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
#
# These are NON-SECRET local development defaults. Never put real credentials in
# this file or in `.env`; `.env` is git-ignored. Production values are supplied
# by the deployment environment, not by the repository.

# --- PostgreSQL (used by the postgres service) ---
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_DB=atlas
POSTGRES_PORT=5432

# --- API service ---
# SQLAlchemy URL. Inside Docker Compose the host is the `postgres` service name.
DATABASE_URL=postgresql+psycopg://atlas:atlas@postgres:5432/atlas  # pragma: allowlist secret
APP_ENV=development
API_PORT=8000

# --- Worker & scheduler services ---
# Idle poll interval (seconds) for the worker claim loop.
WORKER_POLL_INTERVAL_SECONDS=2
# Enqueue interval (seconds) for the scheduler.
SCHEDULER_INTERVAL_SECONDS=5
# Freshness threshold (seconds) for the database-backed liveness health check.
HEARTBEAT_STALE_SECONDS=30

# --- Web frontend service ---
# Host port for the nginx-served React SPA (container listens on 80).
WEB_PORT=8080
# npm registry used when building the web image. Defaults to the public npm
# registry (portable). If your environment blocks or mirrors the public
# registry, set this to your approved feed/proxy; the committed lockfile keeps
# public URLs and npm remaps them to this registry automatically.
NPM_REGISTRY=https://registry.npmjs.org/
