{
  "name": "@freetier-atlas/web",
  "version": "0.1.0-dev.0",
  "private": true,
  "type": "module",
  "description": "FreeTier Atlas web frontend (Vite + React + TypeScript scaffold).",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
